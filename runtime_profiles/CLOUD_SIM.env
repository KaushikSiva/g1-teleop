# Cloud GPU profile for MuJoCo + deploy.
# Set QUEST3_ZMQ_HOST to the Mac IP before launching deploy.

export TELEOP_RUNTIME_PROFILE=CLOUD_SIM
export QUEST3_ZMQ_PORT=5556
export QUEST3_ZMQ_OUT_PORT=5557

# Example:
# export QUEST3_ZMQ_HOST=192.168.1.42
# cd gear_sonic_deploy
# bash deploy.sh --runtime-profile CLOUD_SIM --zmq-host "$QUEST3_ZMQ_HOST" sim
