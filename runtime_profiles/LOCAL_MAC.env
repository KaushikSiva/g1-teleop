# Local Mac profile for Quest 3 teleop.
# Source this before launching the Quest manager on the Mac.

export TELEOP_RUNTIME_PROFILE=LOCAL_MAC
export QUEST3_HTTP_PORT=8443
export QUEST3_WS_PORT=8765
export QUEST3_ZMQ_PORT=5556
export QUEST3_ZMQ_OUT_PORT=5557
export QUEST3_ZMQ_FEEDBACK_HOST=localhost
export QUEST3_ZMQ_FEEDBACK_PORT=5557
